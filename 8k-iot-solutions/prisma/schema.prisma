generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Project {
  id               String   @id @default(cuid())
  slug             String   @unique
  category         String   // "hardware" | "software"
  title            String
  shortDescription String
  fullDescription  String
  coverImage       String
  galleryImages    String   @default("[]") // JSON stringified array
  tags             String   @default("[]") // JSON stringified array
  features         String   @default("[]") // JSON stringified array
  client           String?
  createdAt        DateTime @default(now())
}

model Inquiry {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  inquiryType     String
  message         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  position  String?
  text      String
  avatar    String?
  rating    Int      @default(5)
  createdAt DateTime @default(now())
}

model HeroImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  label     String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolLogo {
  id         String   @id @default(cuid())
  name       String?
  link       String?  
  image      String   
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model HeroSection {
  id                  String   @id @default(cuid())
  heading_part_1      String
  heading_highlight_1 String
  heading_part_2      String
  heading_highlight_2 String
  reveal_text         String?  // The hidden text revealed by the spotlight
  subtext             String
  search_placeholder  String
  updatedAt           DateTime @updatedAt
}

model HeroCard {
  id        String   @id @default(cuid())
  type      String   // "quote", "team", "stat"
  content   String   
  imageUrl  String?  // Optional for team/avatars
  label     String?  // "Hardware Engineer", "Project Request"
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}